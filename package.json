{
  "name": "ai-data-copilot",
  "version": "0.1.0",
  "private": true,
  "description": "AI Data Copilot for Banks - multi-agent text-to-insight engine",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:web",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm-run-all build:server build:web",
    "build:server": "npm --workspace server run build",
    "build:web": "npm --workspace web run build",
    "seed": "npm --workspace server run seed"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
