# Save a copy of this file as `server/.env` (not `server.env` — the name must be `.env`)
PORT=3001

# --- LLM (choose one stack) ---
# Gemini (Google AI): use a Google AI Studio key; set model to a gemini-* id.
GEMINI_API_KEY=
# Or OpenAI-compatible key when using non-Gemini models:
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gemini-2.0-flash
# With Gemini chat models, use a Gemini embedding id (Google AI embedContent), e.g. gemini-embedding-001
OPENAI_EMBED_MODEL=gemini-embedding-001

# Set to false when using a real API key (placeholders still force mock mode).
MOCK_LLM=true

# Local dev (default) — ignored when DATABASE_URL is set
DB_PATH=./data/bank.sqlite

# PostgreSQL (Neon, RDS, local). If set, the app uses this instead of SQLite.
# Never commit real secrets. Rotate the password immediately if a connection string is leaked.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# When true, an empty Neon database (0 transactions) is filled with synthetic banking demo data on first boot.
# Leave false for production or when you load your own data first.
POSTGRES_AUTO_SEED=false

# If the server shows ECONNREFUSED: Neon may be paused, the URL is wrong, or a firewall blocks Postgres.
# Remove DATABASE_URL to fall back to SQLite, or only run the Vite app after the API is up (port 3001).
